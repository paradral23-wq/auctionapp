# ─── Токены ботов ────────────────────────────────────────────
ADMIN_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROUP_BOT_TOKEN=9876543210:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Администраторы (через запятую, Telegram user_id) ─────────
ADMIN_IDS=123456789,987654321

# ─── Группа ───────────────────────────────────────────────────
GROUP_ID=-1001234567890

# ─── База данных ──────────────────────────────────────────────
# SQLite для локальной разработки:
DATABASE_URL=sqlite+aiosqlite:///./auction.db
# PostgreSQL для продакшена:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/auction

# ─── Redis (опционально, не критично при MemoryStorage) ───────
REDIS_URL=redis://localhost:6379/0

# ─── Параметры аукциона ───────────────────────────────────────
ANTISNIPE_MINUTES=2
MIN_BID_STEP=500
