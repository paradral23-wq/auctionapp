# ─── Токен группового бота ────────────────────────────────────
GROUP_BOT_TOKEN=9876543210:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Дополнительно нужен токен ADMIN бота ─────────────────────
# (для скачивания фото лотов при публикации карточки)
ADMIN_BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Администраторы ───────────────────────────────────────────
ADMIN_IDS=123456789,987654321

# ─── Группа ───────────────────────────────────────────────────
GROUP_ID=-1001234567890

# ─── Mini App URL ─────────────────────────────────────────────
# Адрес задеплоенного фронтенда (для WebApp-кнопки в /start)
# При локальной разработке — оставьте пустым
MINIAPP_URL=

# ─── База данных (та же что у admin бота!) ────────────────────
DATABASE_URL=sqlite+aiosqlite:///./auction.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/auction

# ─── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Параметры аукциона ───────────────────────────────────────
ANTISNIPE_MINUTES=2
ANTISNIPE_SECONDS=120
MIN_BID_STEP=500
