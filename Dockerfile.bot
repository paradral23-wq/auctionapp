FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

COPY auction_admin_bot/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY auction_admin_bot/ ./auction_admin_bot/
COPY texts.py .

WORKDIR /app/auction_admin_bot
ENV PYTHONPATH=/app
CMD ["python", "bot.py"]
